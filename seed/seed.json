							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Sony A7R IV · Objectifs : 16-35mm f/2.8, 85mm f/1.4, 70-200mm f/2.8. Filtres ND et polarisant pour les longues expositions.",
									"_key": "k7"
								}
							],
							"_key": "k6"
						}
					]
				}
			}
