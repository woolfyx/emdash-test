---
import { getEmDashCollection, getTermsForEntries, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PhotoCard from "../components/PhotoCard.astro";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const [{ entries: photos, cacheHint }, settings] = await Promise.all([
	getEmDashCollection("photos", {
		orderBy: { published_at: "desc" },
		limit: 9,
	}),
	getSiteSettings(),
]);
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(settings);

Astro.cache.set(cacheHint);

// Hero = première photo
const heroPhoto = photos.find((p) => p.data.featured_image);
const heroIndex = heroPhoto ? photos.indexOf(heroPhoto) : -1;
const gridPhotos = photos.filter((_, i) => i !== heroIndex).slice(0, 8);

const genresByEntry = await getTermsForEntries(
	"photos",
	gridPhotos.map((p) => p.data.id),
	"genre"
);

const gridPhotosWithGenres = gridPhotos.map((photo) => ({
	photo,
	genres: (genresByEntry.get(photo.data.id) ?? []).map((t) => ({
		slug: t.slug,
		label: t.label,
	})),
}));

function getHeroImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) return image.src;
	const meta = image.meta as Record<string, unknown> | undefined;
	const key =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (key) return `${Astro.url.origin}/_emdash/api/media/file/${key}`;
	return undefined;
}
const heroImageUrl = heroPhoto ? getHeroImageUrl(heroPhoto.data.featured_image) : undefined;
---

<Base title={siteTitle} description={siteTagline} image={heroImageUrl}>
	{
		photos.length === 0 ? (
			<section class="empty-state">
				<h2>Aucune photo pour l'instant</h2>
				<p>Ajoutez vos premières photos depuis le panneau d'administration.</p>
				<a href="/_emdash/admin/content/photos/new" class="btn">
					Ajouter une photo
				</a>
			</section>
		) : (
			<div class="home-content">
				{/* Hero */}
				{heroPhoto && (
					<section class="hero-section">
						<a href={`/photos/${heroPhoto.id}`} class="hero-link">
							<div class="hero-image">
								<Image image={heroPhoto.data.featured_image} />
							</div>
							<div class="hero-overlay">
								<div class="hero-meta">
									{heroPhoto.data.location && (
										<span class="hero-location">{heroPhoto.data.location}</span>
									)}
								</div>
								<h1 class="hero-title">{heroPhoto.data.title}</h1>
								<span class="hero-cta">Voir la photo →</span>
							</div>
						</a>
					</section>
				)}

				{/* Intro */}
				<section class="intro-section">
					<p class="intro-tagline">{siteTagline}</p>
					<div class="intro-genres">
						<a href="/photos?genre=paysage" class="genre-pill">Paysage</a>
						<a href="/photos?genre=portrait" class="genre-pill">Portrait</a>
						<a href="/photos?genre=architecture" class="genre-pill">Architecture</a>
						<a href="/photos?genre=rue" class="genre-pill">Rue</a>
						<a href="/photos?genre=nature" class="genre-pill">Nature</a>
					</div>
				</section>

				{/* Grille */}
				{gridPhotosWithGenres.length > 0 && (
					<section class="grid-section">
						<div class="photos-grid">
							{gridPhotosWithGenres.map(({ photo, genres }, i) => {
								// Row 1: 3 equal (i=0,1,2)
								// Row 2: wide 2/3 + normal 1/3 (i=3 wide, i=4 normal)
								// Row 3: normal 1/3 + wide 2/3 (i=5 normal, i=6 wide)
								const isWide = i === 3 || i === 6;
								return (
									<div class={`grid-item${isWide ? " grid-item--wide" : ""}`}>
										<PhotoCard
											title={photo.data.title ?? "Sans titre"}
											location={photo.data.location}
											featuredImage={photo.data.featured_image}
											href={`/photos/${photo.id}`}
											genres={genres}
											aspectRatio="landscape"
										/>
									</div>
								);
							})}
						</div>
						<div class="grid-footer">
							<a href="/photos" class="btn-gallery">
								Voir toute la galerie
							</a>
						</div>
					</section>
				)}
			</div>
		)
	}
</Base>

<style>
	.home-content {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	/* Hero */
	.hero-section {
		position: relative;
	}

	.hero-link {
		display: block;
		position: relative;
		text-decoration: none;
		overflow: hidden;
	}

	.hero-image {
		width: 100%;
		height: calc(100vh - var(--nav-height));
		max-height: 900px;
		min-height: 500px;
	}

	.hero-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.hero-link:hover .hero-image :global(img) {
		transform: scale(1.02);
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to top,
			rgba(0, 0, 0, 0.65) 0%,
			rgba(0, 0, 0, 0.1) 60%,
			transparent 100%
		);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: var(--spacing-12) var(--spacing-10);
		color: white;
	}

	.hero-meta {
		margin-bottom: var(--spacing-3);
	}

	.hero-location {
		font-size: var(--font-size-sm);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-accent);
		font-weight: 500;
	}

	.hero-title {
		font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		color: white;
		max-width: 700px;
		margin-bottom: var(--spacing-4);
	}

	.hero-cta {
		font-size: var(--font-size-sm);
		color: rgba(255, 255, 255, 0.75);
		transition: color var(--transition-fast);
	}

	.hero-link:hover .hero-cta {
		color: white;
	}

	/* Intro */
	.intro-section {
		padding: var(--spacing-12) var(--spacing-8);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-8);
		flex-wrap: wrap;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.intro-tagline {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		max-width: 480px;
		line-height: var(--leading-relaxed);
	}

	.intro-genres {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.genre-pill {
		display: inline-block;
		padding: var(--spacing-2) var(--spacing-4);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition:
			color var(--transition-fast),
			border-color var(--transition-fast),
			background var(--transition-fast);
	}

	.genre-pill:hover {
		color: var(--color-accent);
		border-color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent) 6%, transparent);
	}

	/* Grid */
	.grid-section {
		padding: var(--spacing-12) var(--spacing-8);
	}

	.photos-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-3);
	}

	.grid-item--wide {
		grid-column: span 2;
	}

	.grid-footer {
		display: flex;
		justify-content: center;
		margin-top: var(--spacing-12);
	}

	.btn-gallery {
		display: inline-block;
		padding: var(--spacing-4) var(--spacing-8);
		border: 1px solid var(--color-accent);
		color: var(--color-accent);
		text-decoration: none;
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		border-radius: var(--radius);
		transition:
			background var(--transition-base),
			color var(--transition-base);
	}

	.btn-gallery:hover {
		background: var(--color-accent);
		color: white;
	}

	/* Empty State */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-3);
		text-align: center;
		padding: var(--spacing-20) var(--spacing-6);
		max-width: 400px;
		margin: 0 auto;
	}

	.empty-state h2 {
		font-size: var(--font-size-2xl);
		font-weight: 600;
	}

	.empty-state p {
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: white;
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
		transition: background var(--transition-fast);
	}

	.btn:hover {
		background: var(--color-accent-hover);
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.hero-overlay {
			padding: var(--spacing-8) var(--spacing-6);
		}

		.photos-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.grid-item--wide {
			grid-column: span 2;
		}
	}

	@media (max-width: 640px) {
		.hero-image {
			height: 70vw;
			min-height: 300px;
		}

		.hero-title {
			font-size: var(--font-size-2xl);
		}

		.hero-overlay {
			padding: var(--spacing-6) var(--spacing-4);
		}

		.intro-section {
			padding: var(--spacing-8) var(--spacing-4);
			flex-direction: column;
			align-items: flex-start;
		}

		.grid-section {
			padding: var(--spacing-8) var(--spacing-4);
		}

		.photos-grid {
			grid-template-columns: 1fr;
		}

		.grid-item--wide {
			grid-column: span 1;
		}
	}
</style>
